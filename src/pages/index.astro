---
// Wayfinder — Seguimiento del mapa curricular Ingeniero en Software 2023 (ITSON)
// Copyright (c) 2026 Manuel Cortez y Sebastián Escalante (Oyzters)
// SPDX-License-Identifier: MIT · Ver archivo LICENSE en la raíz del proyecto.
import {
  BLOCKS,
  STATUSES,
  SEMESTERS,
  ENGLISH,
  EXTRACURRICULARES,
} from "../data/curriculum.js";

const LIGHT_BLOCKS = new Set(["admin_proyectos", "practica_profesional"]);

/** Helpers de render */
const inkFor = (block) => (LIGHT_BLOCKS.has(block) ? "#23272e" : "#ffffff");
const metaText = (course) =>
  course.credits > 0
    ? `${course.hours} · ${course.credits.toFixed(2)} c`
    : course.hours;

const blockEntries = Object.entries(BLOCKS);
const statusEntries = Object.entries(STATUSES);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Seguimiento del mapa curricular — Ingeniería en Software 2023 (ITSON)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Wayfinder · Ingeniería en Software 2023</title>
    <script is:inline>
      // Guard: solo escritorio. Detecta móvil/tablet (UA o puntero táctil).
      (function () {
        try {
          var ua = navigator.userAgent || "";
          var mobileUA =
            /Android|iPhone|iPad|iPod|IEMobile|BlackBerry|Opera Mini|Mobile|Silk/i.test(
              ua
            );
          var coarse =
            window.matchMedia && window.matchMedia("(pointer: coarse)").matches;
          if (mobileUA || coarse)
            document.documentElement.classList.add("is-mobile");
        } catch (e) {}
      })();
      // Tema: aplica antes de pintar para evitar parpadeo (FOUC).
      (function () {
        try {
          var t = localStorage.getItem("wayfinder:theme");
          // Sin preferencia guardada: siempre modo claro (no se sigue el
          // ajuste del sistema operativo).
          if (t !== "dark" && t !== "light") {
            t = "light";
          }
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!-- Guard móvil: solo se muestra en teléfonos/tablets -->
    <div class="mobile-gate">
      <div class="gate-card">
        <span class="brand-badge">ISW</span>
        <h1>Wayfinder</h1>
        <p class="gate-title">Disponible solo en computadora</p>
        <p class="gate-sub">
          El mapa curricular necesita una pantalla amplia para verse bien.
          Ábrelo desde una laptop o PC de escritorio para marcar tu progreso.
        </p>
      </div>
    </div>

    <div class="app">
      <!-- Encabezado -->
      <header class="topbar">
        <div class="brand">
          <span class="brand-badge">ISW</span>
          <div class="brand-text">
            <h1>Wayfinder</h1>
            <p>Ingeniero en Software 2023 · ITSON</p>
          </div>
        </div>

        <div class="progress-wrap">
          <div class="progress-head">
            <span class="progress-label">Progreso del plan</span>
            <span class="progress-pct" id="pct">0%</span>
          </div>
          <div class="bar-track"><div class="bar-fill" id="bar"></div></div>
          <div class="progress-sub">
            <span><b id="cr-done">0.00</b> / <span id="cr-total">0.00</span> créditos completados</span>
          </div>
        </div>

        <div class="stats">
          <div class="stat s-completada"><b id="n-completada">0</b><span>Completadas</span></div>
          <div class="stat s-en_curso"><b id="n-en_curso">0</b><span>En curso</span></div>
          <div class="stat s-planeada"><b id="n-planeada">0</b><span>Planeadas</span></div>
          <div class="stat s-pendiente"><b id="n-pendiente">0</b><span>Pendientes</span></div>
        </div>

        <button
          class="theme-toggle"
          id="theme-toggle"
          type="button"
          role="switch"
          aria-checked="false"
          aria-label="Cambiar entre modo claro y oscuro"
          title="Modo claro / oscuro"
        >
          <span class="tt-track">
            <svg class="tt-ic tt-sun" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10zM12 1v3M12 20v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M1 12h3M20 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1" />
            </svg>
            <svg class="tt-ic tt-moon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
            </svg>
            <span class="tt-thumb"></span>
          </span>
        </button>

        <a
          class="repo-link"
          href="https://github.com/oyzters/Wayfinder"
          target="_blank"
          rel="noopener noreferrer"
          title="Apóyalo con una ⭐ en GitHub"
        >
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
          </svg>
          <span>GitHub</span>
        </a>
      </header>

      <!-- Barra de ayuda / acciones -->
      <div class="toolbar">
        <p class="hint">
          <b>Clic</b> para avanzar el estado · <b>Clic derecho</b> para retroceder
        </p>
        <div class="status-legend">
          {statusEntries.map(([key, s]) => (
            <span class={`chip st-${key}`}><i class="dot"></i>{s.label}</span>
          ))}
        </div>
        <div class="wires-toggle" role="group" aria-label="Flechas de seriación">
          <span class="wt-label">Prerrequisitos</span>
          <button class="wt-opt" data-wires-mode="always" type="button">Siempre</button>
          <button class="wt-opt" data-wires-mode="hover" type="button">Al pasar</button>
          <button class="wt-opt" data-wires-mode="off" type="button">Ocultar</button>
        </div>
        <button class="btn-reset" id="reset" type="button">Reiniciar</button>
        <button class="btn-share" id="share" type="button">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2 8 6h3v8h2V6h3l-4-4zM4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8h-2v8H6v-8H4z" />
          </svg>
          <span>Compartir</span>
        </button>
      </div>

      <!-- Mapa curricular -->
      <div class="map-scroll">
        <div class="map" data-wires="hover">
          <!-- Capa de flechas de seriación (prerrequisitos).
               Capas (halo/línea/cabeza) se crean por JS. -->
          <svg class="wires" aria-hidden="true" fill="none"></svg>

          <!-- Cabeceras de semestre -->
          <div class="sem-heads">
            {SEMESTERS.map((_, i) => (
              <div class="sem-head" data-sem={i} title="Clic para marcar el semestre"><span>{i + 1}</span></div>
            ))}
          </div>

          <!-- Columnas -->
          <div class="grid">
            {SEMESTERS.map((semester) => (
              <div class="col">
                {semester.map((course) => (
                  <button
                    class="course"
                    data-id={course.id}
                    data-status="pendiente"
                    data-block={course.block}
                    style={`--c:${BLOCKS[course.block].color};--ink:${inkFor(course.block)}`}
                    title={`${course.name} — ${BLOCKS[course.block].label}`}
                  >
                    <span class="badge"></span>
                    <span class="lock" aria-hidden="true">
                      <svg viewBox="0 0 24 24"><path d="M6 10V8a6 6 0 1 1 12 0v2h1a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-9a1 1 0 0 1 1-1h1zm2 0h8V8a4 4 0 0 0-8 0v2z"/></svg>
                    </span>
                    <span class="c-name">{course.name}</span>
                    <span class="c-foot">
                      <span class="c-status"></span>
                      <span class="c-meta">{metaText(course)}</span>
                    </span>
                  </button>
                ))}
              </div>
            ))}
          </div>

          <!-- Zona inferior: Inglés + Extracurriculares (izq) y leyenda (der),
               al estilo del mapa oficial: aprovecha el hueco inferior derecho. -->
          <div class="map-bottom">
            <div class="mb-label mb-label--ing">Inglés universitario</div>
            {ENGLISH.map((course, i) => (
              <button
                class="course mb-ing"
                data-id={course.id}
                data-status="pendiente"
                data-block="ingles"
                style={`--c:${BLOCKS.ingles.color};--ink:#ffffff;grid-column:${i + 1}/${i + 2};grid-row:2`}
                title={`${course.name} — Inglés universitario`}
              >
                <span class="badge"></span>
                <span class="lock" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M6 10V8a6 6 0 1 1 12 0v2h1a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-9a1 1 0 0 1 1-1h1zm2 0h8V8a4 4 0 0 0-8 0v2z"/></svg>
                </span>
                <span class="c-name">{course.name}</span>
                <span class="c-foot">
                  <span class="c-status"></span>
                  <span class="c-meta">{metaText(course)}</span>
                </span>
              </button>
            ))}
            <div class="mb-label mb-label--extra">Extracurriculares</div>
            {EXTRACURRICULARES.map((course, j) => (
              <button
                class="course course--extra mb-extra"
                data-id={course.id}
                data-status="pendiente"
                data-block={course.block}
                style={`--c:${BLOCKS[course.block].color};--ink:#23272e;grid-column:${j + 1}/${j + 2};grid-row:4`}
                title={`${course.name} — Extracurricular`}
              >
                <span class="badge"></span>
                <span class="c-name">{course.name}</span>
                <span class="c-foot">
                  <span class="c-status"></span>
                  <span class="c-meta">{metaText(course)}</span>
                </span>
              </button>
            ))}

            <!-- Leyenda de bloques (vertical, esquina inferior derecha) -->
            <section class="blocks">
              <h2>Bloques del programa</h2>
              <div class="blocks-grid">
                {blockEntries.map(([key, b]) => (
                  <div class="block-item">
                    <span class="swatch" style={`background:${b.color}`}></span>
                    <span class="block-name">{b.label}</span>
                    <span class="block-count" data-block-count={key}>0/0</span>
                  </div>
                ))}
              </div>
            </section>
          </div>
        </div>
      </div>

      <footer class="foot">
        <span>Datos locales · guardado automático en este navegador (localStorage)</span>
        <span class="foot-legal">
          © 2026 Manuel Cortez y Sebastián Escalante (Oyzters) ·
          Licencia
          <a
            href="https://github.com/oyzters/Wayfinder/blob/main/LICENSE"
            target="_blank"
            rel="noopener noreferrer"
          >MIT</a>
          · Todos los derechos reservados
        </span>
      </footer>
    </div>

    <!-- Modal de confirmación de reinicio -->
    <div class="modal-overlay" id="reset-modal" hidden>
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="reset-title">
        <div class="modal-icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 9v4m0 4h.01M10.3 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.7 3.86a2 2 0 0 0-3.42 0z" />
          </svg>
        </div>
        <h3 id="reset-title">¿Reiniciar todo el progreso?</h3>
        <p>Se borrará el estado de todas las materias. Esta acción no se puede deshacer.</p>
        <div class="modal-actions">
          <button class="btn-ghost" id="reset-cancel" type="button">Cancelar</button>
          <button class="btn-danger" id="reset-confirm" type="button">Sí, reiniciar</button>
        </div>
      </div>
    </div>

    <!-- Popover flotante de acciones por semestre (clic en el número) -->
    <div class="sem-pop" id="sem-modal" role="menu" aria-labelledby="sem-title" hidden>
      <div class="sem-pop-title" id="sem-title">Semestre</div>
      <button class="sem-pop-opt" id="sem-complete" type="button" role="menuitem">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 13l4 4L19 7" />
        </svg>
        <span>Completar hasta este semestre</span>
      </button>
      <button class="sem-pop-opt" id="sem-encurso" type="button" role="menuitem">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 8v4l3 2M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
        </svg>
        <span>Marcar como semestre en curso</span>
      </button>
    </div>

    <script>
      import {
        ALL_COURSES,
        STATUS_ORDER,
        PREREQS,
        PREREQ_EDGES,
        UNLOCKS,
        SEMESTERS,
        ENGLISH,
        EXTRACURRICULARES,
      } from "../data/curriculum.js";
      import { toPng } from "html-to-image";

      const nameOf = (id) => {
        const c = ALL_COURSES.find((x) => x.id === id);
        return c ? c.name : id;
      };

      const KEY = "wayfinder:v1";
      let state = load();

      function load() {
        try {
          return JSON.parse(localStorage.getItem(KEY) || "{}") || {};
        } catch {
          return {};
        }
      }
      function save() {
        localStorage.setItem(KEY, JSON.stringify(state));
      }
      const statusOf = (id) => state[id] || "pendiente";
      const set = (sel, v) => {
        const e = document.querySelector(sel);
        if (e) e.textContent = String(v);
      };

      function setStatus(id, s) {
        if (s === "pendiente") delete state[id];
        else state[id] = s;
        save();
        const el = document.querySelector(`[data-id="${id}"]`);
        if (el) el.setAttribute("data-status", statusOf(id));
        renderProgress();
      }

      function cycle(id, dir) {
        const i = STATUS_ORDER.indexOf(statusOf(id));
        const next =
          STATUS_ORDER[(i + dir + STATUS_ORDER.length) % STATUS_ORDER.length];
        setStatus(id, next);
      }

      function renderProgress() {
        const credited = ALL_COURSES.filter((c) => c.credits > 0);
        const totalCr = credited.reduce((s, c) => s + c.credits, 0);
        const doneCr = credited
          .filter((c) => statusOf(c.id) === "completada")
          .reduce((s, c) => s + c.credits, 0);
        const pct = totalCr ? Math.round((doneCr / totalCr) * 100) : 0;

        const counts = { pendiente: 0, planeada: 0, en_curso: 0, completada: 0 };
        ALL_COURSES.forEach((c) => counts[statusOf(c.id)]++);

        set("#pct", pct + "%");
        const bar = document.querySelector("#bar");
        if (bar) bar.style.width = pct + "%";
        set("#cr-done", doneCr.toFixed(2));
        set("#cr-total", totalCr.toFixed(2));
        set("#n-completada", counts.completada);
        set("#n-en_curso", counts.en_curso);
        set("#n-planeada", counts.planeada);
        set("#n-pendiente", counts.pendiente);

        document.querySelectorAll("[data-block-count]").forEach((el) => {
          const b = el.getAttribute("data-block-count");
          const list = ALL_COURSES.filter((c) => c.block === b);
          const done = list.filter((c) => statusOf(c.id) === "completada").length;
          el.textContent = `${done}/${list.length}`;
        });

        updateLocks();
        scheduleWireLayout();
      }

      /* ---------- Candados de prerrequisitos ---------- */
      function updateLocks() {
        ALL_COURSES.forEach((course) => {
          const reqs = PREREQS[course.id] || [];
          const el = document.querySelector(`[data-id="${course.id}"]`);
          if (!el) return;
          const done = statusOf(course.id) === "completada";
          const missing = reqs.filter((r) => statusOf(r) !== "completada");
          const locked = !done && missing.length > 0;
          el.setAttribute("data-locked", locked ? "true" : "false");
          if (locked) {
            const list = missing.map(nameOf).join(", ");
            el.setAttribute(
              "data-lock-hint",
              `Faltan prerrequisitos: ${list}`
            );
          } else {
            el.removeAttribute("data-lock-hint");
          }
        });
      }

      function applyAll() {
        document.querySelectorAll("[data-id]").forEach((el) => {
          el.setAttribute("data-status", statusOf(el.getAttribute("data-id")));
        });
        renderProgress();
      }

      document.addEventListener("click", (e) => {
        const el = e.target.closest("[data-id]");
        if (el) cycle(el.getAttribute("data-id"), 1);
      });
      document.addEventListener("contextmenu", (e) => {
        const el = e.target.closest("[data-id]");
        if (el) {
          e.preventDefault();
          cycle(el.getAttribute("data-id"), -1);
        }
      });
      // Bloquea el scroll/movimiento del fondo mientras haya un modal abierto.
      const lockScroll = (on) =>
        document.documentElement.classList.toggle("modal-open", on);

      const resetBtn = document.querySelector("#reset");
      const resetModal = document.querySelector("#reset-modal");
      const closeResetModal = () => {
        if (resetModal) resetModal.hidden = true;
        lockScroll(false);
      };
      if (resetBtn && resetModal) {
        resetBtn.addEventListener("click", () => {
          resetModal.hidden = false;
          lockScroll(true);
          const cancel = document.querySelector("#reset-cancel");
          if (cancel) cancel.focus();
        });
        resetModal.addEventListener("click", (e) => {
          if (e.target === resetModal) closeResetModal();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && !resetModal.hidden) closeResetModal();
        });
        const cancelBtn = document.querySelector("#reset-cancel");
        if (cancelBtn) cancelBtn.addEventListener("click", closeResetModal);
        const confirmBtn = document.querySelector("#reset-confirm");
        if (confirmBtn)
          confirmBtn.addEventListener("click", () => {
            state = {};
            save();
            applyAll();
            closeResetModal();
          });
      }

      /* ---------- Acciones por semestre (clic derecho en el número) ---------- */
      function semCourseIds(i) {
        const ids = (SEMESTERS[i] || []).map((c) => c.id);
        if (ENGLISH[i]) ids.push(ENGLISH[i].id);
        if (EXTRACURRICULARES[i]) ids.push(EXTRACURRICULARES[i].id);
        return ids;
      }
      // Marca los semestres 0..upto: todos "completada", salvo el último
      // (upto) que toma lastStatus.
      function markSemesters(upto, lastStatus) {
        for (let i = 0; i <= upto; i++) {
          const st = i === upto ? lastStatus : "completada";
          semCourseIds(i).forEach((id) => {
            state[id] = st;
          });
        }
        save();
        applyAll();
      }

      const semModal = document.querySelector("#sem-modal");
      const semTitle = document.querySelector("#sem-title");
      let semTarget = null;
      const closeSemModal = () => {
        if (semModal) semModal.hidden = true;
      };
      // Coloca el popover cerca del número clicado, sin salirse de la pantalla.
      function positionSemPop(head) {
        const r = head.getBoundingClientRect();
        semModal.style.visibility = "hidden";
        semModal.hidden = false;
        const pw = semModal.offsetWidth;
        const ph = semModal.offsetHeight;
        const gap = 8;
        let left = r.left;
        let top = r.bottom + gap;
        if (left + pw > window.innerWidth - 8)
          left = window.innerWidth - 8 - pw;
        if (left < 8) left = 8;
        // Si no cabe abajo, lo abre hacia arriba.
        if (top + ph > window.innerHeight - 8 && r.top - gap - ph > 8)
          top = r.top - gap - ph;
        semModal.style.left = Math.round(left) + "px";
        semModal.style.top = Math.round(top) + "px";
        semModal.style.visibility = "";
      }
      document.addEventListener("click", (e) => {
        const head = e.target.closest("[data-sem]");
        if (!head) return;
        semTarget = parseInt(head.getAttribute("data-sem"), 10);
        if (semTitle) semTitle.textContent = "Semestre " + (semTarget + 1);
        if (semModal) {
          positionSemPop(head);
          const b = document.querySelector("#sem-complete");
          if (b) b.focus();
        }
      });
      if (semModal) {
        // Clic fuera cierra (ignora el número clicado y el propio popover).
        document.addEventListener("click", (e) => {
          if (semModal.hidden) return;
          if (e.target.closest("[data-sem]")) return;
          if (semModal.contains(e.target)) return;
          closeSemModal();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && !semModal.hidden) closeSemModal();
        });
        // Cerrar al hacer scroll o redimensionar (comportamiento de combobox).
        window.addEventListener(
          "scroll",
          () => {
            if (!semModal.hidden) closeSemModal();
          },
          true
        );
        window.addEventListener("resize", () => {
          if (!semModal.hidden) closeSemModal();
        });
        const comp = document.querySelector("#sem-complete");
        if (comp)
          comp.addEventListener("click", () => {
            if (semTarget != null) markSemesters(semTarget, "completada");
            closeSemModal();
          });
        const enc = document.querySelector("#sem-encurso");
        if (enc)
          enc.addEventListener("click", () => {
            if (semTarget != null) markSemesters(semTarget, "en_curso");
            closeSemModal();
          });
      }

      /* ---------- Compartir: exportar el mapa como imagen PNG ---------- */
      const mapEl = document.querySelector(".map");
      const shareBtn = document.querySelector("#share");
      if (shareBtn) shareBtn.addEventListener("click", exportImage);

      function buildPoster() {
        const g = (sel) => {
          const e = document.querySelector(sel);
          return e ? e.textContent : "";
        };
        const poster = document.createElement("div");
        poster.className = "poster";
        // Mismo ancho que el mapa en vivo (para conservar el layout y que las
        // flechas ya calculadas sigan alineadas).
        const mapW = Math.round(mapEl.getBoundingClientRect().width);
        poster.style.width = mapW + 56 + "px"; // mapa + 28*2 padding

        const head = document.createElement("div");
        head.className = "poster-head";
        head.innerHTML =
          '<div class="poster-brand"><span class="brand-badge">ISW</span>' +
          "<div><h1>Wayfinder — Mapa Curricular</h1>" +
          "<p>Ingeniero en Software 2023 · ITSON</p></div></div>" +
          '<div class="poster-stats"><div class="ps-pct">' +
          g("#pct") +
          '</div><div class="ps-cr">' +
          g("#cr-done") +
          " / " +
          g("#cr-total") +
          ' créditos</div><div class="ps-counts">' +
          '<b style="color:var(--st-completada)">' +
          g("#n-completada") +
          "</b> compl · " +
          '<b style="color:var(--st-en_curso)">' +
          g("#n-en_curso") +
          "</b> en curso · " +
          '<b style="color:var(--st-planeada-ink)">' +
          g("#n-planeada") +
          "</b> plan · " +
          '<b style="color:var(--st-pendiente)">' +
          g("#n-pendiente") +
          "</b> pend</div></div>";
        poster.appendChild(head);

        // Clon con el MISMO ancho que el mapa en vivo → el svg de flechas (con
        // coordenadas ya calculadas) sigue alineado con las tarjetas.
        const mapClone = mapEl.cloneNode(true);
        mapClone.style.width = mapW + "px";
        mapClone.style.minWidth = mapW + "px";
        // Se respeta el modo de flechas actual (Siempre / Al pasar / Ocultar):
        // data-wires y el overlay se conservan tal cual están en la app. Solo se
        // limpia el resaltado temporal de hover (por si se exporta con el cursor
        // encima de una materia).
        mapClone
          .querySelectorAll(".is-dim,.is-related,.is-active")
          .forEach((el) =>
            el.classList.remove("is-dim", "is-related", "is-active")
          );

        poster.appendChild(mapClone);

        const foot = document.createElement("div");
        foot.className = "poster-foot";
        foot.innerHTML =
          "github.com/oyzters/Wayfinder<br>" +
          "© 2026 Manuel Cortez y Sebastián Escalante (Oyzters) · Licencia MIT";
        poster.appendChild(foot);

        return poster;
      }

      // Copia las flechas (svg) computadas del documento dado como estilo en
      // línea (html-to-image no aplica CSS a elementos SVG).
      function inlineWireStyles(poster, win) {
        const wires = poster.querySelector(".wires");
        if (!wires) return;
        const props = [
          "display", "opacity", "fill", "stroke", "stroke-width",
          "stroke-linecap", "stroke-linejoin", "paint-order",
        ];
        const els = [wires, ...wires.querySelectorAll("*")];
        for (const el of els) {
          const cs = win.getComputedStyle(el);
          let s = el.getAttribute("style") || "";
          for (const p of props) {
            const v = cs.getPropertyValue(p);
            if (v) s += `${p}:${v};`;
          }
          el.setAttribute("style", s);
        }
      }

      async function exportImage() {
        if (!mapEl || !shareBtn) return;
        const label = shareBtn.querySelector("span") || shareBtn;
        const prev = label.textContent;
        label.textContent = "Generando…";
        shareBtn.disabled = true;

        const root = document.documentElement;
        const prevTheme = root.getAttribute("data-theme");

        // La imagen SIEMPRE se exporta en modo claro. Para que la app visible NO
        // parpadee al cambiar de tema, cubrimos la pantalla con un velo opaco del
        // color del tema ACTUAL: el cambio a claro ocurre detrás del velo.
        const cs0 = getComputedStyle(root);
        const curBg = cs0.getPropertyValue("--bg").trim() || "#0f1217";
        const curInk = cs0.getPropertyValue("--ink-2").trim() || "#8a92a0";
        const cover = document.createElement("div");
        cover.style.cssText =
          "position:fixed;inset:0;z-index:9999;display:grid;place-items:center;" +
          `background:${curBg};color:${curInk};` +
          "font:600 14px 'Segoe UI',system-ui,sans-serif;";
        cover.textContent = "Generando imagen…";
        document.body.appendChild(cover);

        root.setAttribute("data-theme", "light");

        const holder = document.createElement("div");
        holder.style.cssText = "position:fixed;left:-100000px;top:0;";
        const poster = buildPoster();
        holder.appendChild(poster);
        document.body.appendChild(holder);

        try {
          if (document.fonts && document.fonts.ready) await document.fonts.ready;
          void poster.offsetHeight;
          // Inline de estilos de flechas (el doc ya está en claro).
          inlineWireStyles(poster, window);

          const bg =
            getComputedStyle(root).getPropertyValue("--bg").trim() || "#ffffff";
          const opts = {
            pixelRatio: 2,
            backgroundColor: bg,
            cacheBust: true,
            width: poster.offsetWidth,
            height: poster.offsetHeight,
          };
          // Primer render de "calentamiento" (evita imágenes en blanco).
          await toPng(poster, opts);
          const dataUrl = await toPng(poster, opts);

          const d = new Date();
          const pad = (n) => String(n).padStart(2, "0");
          const stamp =
            pad(d.getDate()) +
            "-" +
            pad(d.getMonth() + 1) +
            "-" +
            pad(d.getFullYear() % 100);
          const a = document.createElement("a");
          a.href = dataUrl;
          a.download = "wayfinder-isw-" + stamp + ".png";
          a.click();
        } catch (err) {
          console.error(err);
          alert("No se pudo generar la imagen. Intenta de nuevo.");
        } finally {
          holder.remove();
          // Restaurar el tema del usuario ANTES de quitar el velo.
          if (prevTheme === null) root.removeAttribute("data-theme");
          else root.setAttribute("data-theme", prevTheme);
          cover.remove();
          shareBtn.disabled = false;
          label.textContent = prev;
        }
      }

      /* ---------- Flechas de seriación (overlay SVG) ---------- */
      const svg = document.querySelector(".wires");
      const SVGNS = "http://www.w3.org/2000/svg";
      let activeId = null;
      let wireRAF = 0;

      // Tres capas apiladas: halos (abajo), líneas (medio), cabezas (arriba).
      // Así los semicírculos siempre quedan por encima de cualquier línea.
      const mkLayer = () => {
        const g = document.createElementNS(SVGNS, "g");
        svg.appendChild(g);
        return g;
      };
      const layerHalo = mkLayer();
      const layerLine = mkLayer();
      const layerHead = mkLayer();

      const wireEls = PREREQ_EDGES.map(([from, to], i) => {
        const cg = i % 5; // color inicial; layoutWires lo recolorea por conflictos
        const halo = document.createElementNS(SVGNS, "path");
        halo.setAttribute("class", "wire-halo");
        const line = document.createElementNS(SVGNS, "path");
        line.setAttribute("class", "wire-line");
        const head = document.createElementNS(SVGNS, "path");
        head.setAttribute("class", "wire-head");
        layerHalo.appendChild(halo);
        layerLine.appendChild(line);
        layerHead.appendChild(head);
        return { from, to, cg, halo, line, head };
      });

      // Reparte el punto de anclaje a lo largo del borde de la card cuando
      // varias flechas comparten origen (o destino).
      function anchorY(r, n, i) {
        if (n <= 1) return r.cy;
        const band = Math.min(r.h * 0.6, (n - 1) * 16);
        return r.cy - band / 2 + (band * i) / (n - 1);
      }

      // Polilínea ortogonal con esquinas redondeadas a partir de puntos.
      function roundedPath(pts, r) {
        const p = [];
        for (const q of pts) {
          const last = p[p.length - 1];
          if (!last || Math.abs(last.x - q.x) > 0.5 || Math.abs(last.y - q.y) > 0.5)
            p.push(q);
        }
        if (p.length < 2) return "";
        const f = (n) => n.toFixed(1);
        let d = `M ${f(p[0].x)} ${f(p[0].y)}`;
        for (let i = 1; i < p.length - 1; i++) {
          const a = p[i - 1];
          const c = p[i];
          const b = p[i + 1];
          const d1 = Math.hypot(c.x - a.x, c.y - a.y) || 1;
          const d2 = Math.hypot(b.x - c.x, b.y - c.y) || 1;
          const rr = Math.max(0, Math.min(r, d1 / 2, d2 / 2));
          const c1 = { x: c.x + ((a.x - c.x) / d1) * rr, y: c.y + ((a.y - c.y) / d1) * rr };
          const c2 = { x: c.x + ((b.x - c.x) / d2) * rr, y: c.y + ((b.y - c.y) / d2) * rr };
          d += ` L ${f(c1.x)} ${f(c1.y)} Q ${f(c.x)} ${f(c.y)} ${f(c2.x)} ${f(c2.y)}`;
        }
        const last = p[p.length - 1];
        d += ` L ${f(last.x)} ${f(last.y)}`;
        return d;
      }

      // Semicírculo (punta) con el lado curvo rozando el borde del destino.
      function headPath(tx, ty, R) {
        return `M ${tx - R} ${ty - R} A ${R} ${R} 0 0 1 ${tx - R} ${ty + R} Z`;
      }

      // Distancia punto-segmento y segmento-segmento (para detectar cruces).
      function ptSeg(p, a, b) {
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const l2 = dx * dx + dy * dy || 1;
        let t = ((p.x - a.x) * dx + (p.y - a.y) * dy) / l2;
        t = Math.max(0, Math.min(1, t));
        return Math.hypot(p.x - (a.x + t * dx), p.y - (a.y + t * dy));
      }
      function segCross(a, b, c, d) {
        const o = (p, q, r) =>
          Math.sign((q.x - p.x) * (r.y - p.y) - (q.y - p.y) * (r.x - p.x));
        return o(a, b, c) !== o(a, b, d) && o(c, d, a) !== o(c, d, b);
      }
      function segDist(a, b, c, d) {
        if (segCross(a, b, c, d)) return 0;
        return Math.min(ptSeg(a, c, d), ptSeg(b, c, d), ptSeg(c, a, b), ptSeg(d, a, b));
      }
      const spanOverlap = (a, b) => a[1] > b[0] + 1 && b[1] > a[0] + 1;

      function layoutWires() {
        wireRAF = 0;
        if (!svg || !mapEl) return;
        const m = mapEl.getBoundingClientRect();
        svg.setAttribute("width", m.width);
        svg.setAttribute("height", m.height);

        const rect = {};
        document.querySelectorAll("[data-id]").forEach((el) => {
          const b = el.getBoundingClientRect();
          rect[el.getAttribute("data-id")] = {
            left: b.left - m.left,
            right: b.right - m.left,
            top: b.top - m.top,
            cy: b.top + b.height / 2 - m.top,
            h: b.height,
          };
        });

        // --- Geometría de la rejilla (para rutear por los canales/gutters) ---
        const grids = document.querySelectorAll(".grid");
        const cols = [...grids[0].querySelectorAll(".col")].map((c) => {
          const b = c.getBoundingClientRect();
          return { left: b.left - m.left, right: b.right - m.left };
        });
        const vChan = []; // vChan[i] = x del gutter a la derecha de la col i
        for (let i = 0; i < cols.length - 1; i++)
          vChan[i] = (cols[i].right + cols[i + 1].left) / 2;
        const colOf = (x) => {
          let best = 0;
          let bd = Infinity;
          for (let i = 0; i < cols.length; i++) {
            const dd = Math.abs(cols[i].left - x);
            if (dd < bd) {
              bd = dd;
              best = i;
            }
          }
          return best;
        };
        const mainCards = [...grids[0].querySelectorAll(".course")];
        const tops = [
          ...new Set(mainCards.map((c) => Math.round(c.getBoundingClientRect().top - m.top))),
        ].sort((a, b) => a - b);
        const H = mainCards.length ? mainCards[0].getBoundingClientRect().height : 130;
        const GAP = tops.length > 1 ? tops[1] - tops[0] - H : 12;
        const rowTopNear = (cy) => {
          let best = tops[0] || 0;
          let bd = Infinity;
          for (const t of tops) {
            const dd = Math.abs(t + H / 2 - cy);
            if (dd < bd) {
              bd = dd;
              best = t;
            }
          }
          return best;
        };

        // Anclas repartidas por origen/destino.
        const outG = {};
        const inG = {};
        wireEls.forEach((w) => {
          if (!rect[w.from] || !rect[w.to]) return;
          (outG[w.from] || (outG[w.from] = [])).push(w);
          (inG[w.to] || (inG[w.to] = [])).push(w);
        });
        const anchorS = new Map();
        const anchorT = new Map();
        Object.keys(outG).forEach((src) => {
          const arr = outG[src].sort((a, b) => rect[a.to].cy - rect[b.to].cy);
          arr.forEach((w, i) => anchorS.set(w, anchorY(rect[src], arr.length, i)));
        });
        Object.keys(inG).forEach((tg) => {
          const arr = inG[tg].sort((a, b) => rect[a.from].cy - rect[b.from].cy);
          arr.forEach((w, i) => anchorT.set(w, anchorY(rect[tg], arr.length, i)));
        });

        // Mismas dimensiones en ambos modos ("Al pasar" idéntico a "Siempre").
        const R = 3.5; // radio del semicírculo (punta)
        const CR = 5; // radio de esquina

        // ---- Pasada 1: plan de ruta (canales base, sin carriles) ----
        const push = (obj, k, v) => (obj[k] || (obj[k] = [])).push(v);
        const plans = [];
        const vMembers = {}; // canal vertical (x) -> miembros
        const hMembers = {}; // canal horizontal (y) -> miembros
        wireEls.forEach((w) => {
          const rf = rect[w.from];
          const rt = rect[w.to];
          if (!rf || !rt) return;
          const sX = rf.right;
          const sY = anchorS.get(w);
          const tX = rt.left;
          const tY = anchorT.get(w);
          const plan = { w, sX, sY, tX, tY, exLine: tX - 3 };
          const sCol = colOf(rf.left);
          const tCol = colOf(rt.left);
          if (tCol <= sCol) {
            plan.type = "fallback";
          } else if (Math.abs(vChan[sCol] - vChan[tCol - 1]) < 1) {
            plan.type = "adj";
            plan.vx = vChan[sCol];
            plan.midY = (sY + tY) / 2;
            plan.vSpan = [Math.min(sY, tY), Math.max(sY, tY)];
            push(vMembers, Math.round(plan.vx), { plan, kind: "v" });
          } else {
            plan.type = "full";
            plan.vs = vChan[sCol];
            plan.vt = vChan[tCol - 1];
            const above = sY <= tY;
            const tr = rowTopNear(tY);
            plan.hyBase = above ? tr - GAP / 2 : tr + H + GAP / 2;
            plan.hSpan = [Math.min(plan.vs, plan.vt), Math.max(plan.vs, plan.vt)];
            push(vMembers, Math.round(plan.vs), {
              plan, kind: "vs", span: [Math.min(sY, plan.hyBase), Math.max(sY, plan.hyBase)],
            });
            push(vMembers, Math.round(plan.vt), {
              plan, kind: "vt", span: [Math.min(tY, plan.hyBase), Math.max(tY, plan.hyBase)],
            });
            push(hMembers, Math.round(plan.hyBase), { plan, kind: "h" });
          }
          plans.push(plan);
        });

        // ---- Reparto homogéneo de carriles (centrado y equidistante) ----
        const memY = (mem) =>
          mem.kind === "vt" ? mem.plan.tY : mem.kind === "vs" ? mem.plan.sY : mem.plan.midY;
        const setOff = (mem, off) => {
          if (mem.kind === "v") mem.plan.vOff = off;
          else if (mem.kind === "vs") mem.plan.vsOff = off;
          else if (mem.kind === "vt") mem.plan.vtOff = off;
          else mem.plan.hOff = off;
        };
        const assign = (members, maxSpan, base, orderBy) => {
          Object.values(members).forEach((list) => {
            list.sort((a, b) => orderBy(a) - orderBy(b));
            const n = list.length;
            const s = n > 1 ? Math.min(base, maxSpan / (n - 1)) : 0;
            list.forEach((mem, i) => setOff(mem, (i - (n - 1) / 2) * s));
          });
        };
        assign(vMembers, 24, 6, memY); // canal vertical (gutter ancho)
        assign(hMembers, 8, 3, (mem) => mem.plan.sX); // canal horizontal (angosto)

        // ---- Pasada 2: puntos con carriles aplicados ----
        plans.forEach((plan) => {
          const { sX, sY, tX, tY, exLine } = plan;
          if (plan.type === "fallback") {
            plan.pts = [{ x: sX, y: sY }, { x: exLine, y: tY }];
          } else if (plan.type === "adj") {
            const gx = plan.vx + (plan.vOff || 0);
            plan.pts = [
              { x: sX, y: sY }, { x: gx, y: sY }, { x: gx, y: tY }, { x: exLine, y: tY },
            ];
          } else {
            const vsx = plan.vs + (plan.vsOff || 0);
            const vtx = plan.vt + (plan.vtOff || 0);
            const hy = plan.hyBase + (plan.hOff || 0);
            plan.pts = [
              { x: sX, y: sY }, { x: vsx, y: sY }, { x: vsx, y: hy },
              { x: vtx, y: hy }, { x: vtx, y: tY }, { x: exLine, y: tY },
            ];
          }
          plan.segs = [];
          for (let i = 0; i < plan.pts.length - 1; i++)
            plan.segs.push([plan.pts[i], plan.pts[i + 1]]);
        });

        // ---- Grafo de conflictos: se cruzan o se tocan → distinto color ----
        plans.forEach((p) => (p.adj = new Set()));
        const conf = (a, b) => {
          a.adj.add(b);
          b.adj.add(a);
        };
        // (a) co-miembros del mismo canal cuyos tramos se solapan (van pegados)
        const coMembers = (members, spanOf) => {
          Object.values(members).forEach((list) => {
            for (let i = 0; i < list.length; i++)
              for (let j = i + 1; j < list.length; j++)
                if (
                  list[i].plan !== list[j].plan &&
                  spanOverlap(spanOf(list[i]), spanOf(list[j]))
                )
                  conf(list[i].plan, list[j].plan);
          });
        };
        coMembers(vMembers, (m) => m.span || m.plan.vSpan);
        coMembers(hMembers, (m) => m.plan.hSpan);
        // (b) cruces geométricos (perpendiculares en distinto canal)
        for (let i = 0; i < plans.length; i++)
          for (let j = i + 1; j < plans.length; j++) {
            const a = plans[i];
            const b = plans[j];
            if (a.adj.has(b)) continue;
            let hit = false;
            for (const s1 of a.segs)
              for (const s2 of b.segs)
                if (segDist(s1[0], s1[1], s2[0], s2[1]) <= 2.5) { hit = true; break; }
            if (hit) conf(a, b);
          }

        // greedy: color preferido = índice%5, evitando el de vecinos ya fijados
        const NC = 5;
        plans.forEach((p, i) => {
          const used = new Set();
          p.adj.forEach((q) => q.cgTmp != null && used.add(q.cgTmp));
          let c = i % NC;
          if (used.has(c)) {
            c = 0;
            while (c < NC && used.has(c)) c++;
            if (c >= NC) c = i % NC;
          }
          p.cgTmp = c;
        });

        // ---- Render ----
        plans.forEach((plan) => {
          const w = plan.w;
          w.cg = plan.cgTmp;
          const haloPts = plan.pts.map((p) => ({ x: p.x, y: p.y }));
          const li = haloPts.length - 1;
          const hx = plan.tX - 13;
          if (hx > haloPts[li - 1].x + 1) haloPts[li] = { x: hx, y: plan.tY };
          else haloPts.pop();
          w.line.setAttribute("d", roundedPath(plan.pts, CR));
          w.halo.setAttribute("d", roundedPath(haloPts, CR));
          w.head.setAttribute("d", headPath(plan.tX, plan.tY, R));
        });
        wireEls.forEach((w) => {
          if (!rect[w.from] || !rect[w.to]) {
            w.halo.removeAttribute("d");
            w.line.removeAttribute("d");
            w.head.removeAttribute("d");
          }
        });

        paintWires();
      }

      function scheduleWireLayout() {
        if (wireRAF) return;
        wireRAF = requestAnimationFrame(layoutWires);
      }

      function paintWires() {
        wireEls.forEach(({ from, to, cg, halo, line, head }) => {
          let role = "idle";
          if (activeId) {
            if (to === activeId) role = "prereq";
            else if (from === activeId) role = "unlock";
            else role = "mute";
          }
          const c = " cg" + cg;
          halo.setAttribute("class", "wire-halo " + role + c);
          line.setAttribute("class", "wire-line " + role + c);
          head.setAttribute("class", "wire-head " + role + c);
        });
      }

      function setActive(id) {
        activeId = id;
        const related = new Set([id]);
        (PREREQS[id] || []).forEach((r) => related.add(r));
        (UNLOCKS[id] || []).forEach((u) => related.add(u));
        document.querySelectorAll("[data-id]").forEach((el) => {
          const cid = el.getAttribute("data-id");
          el.classList.toggle("is-related", related.has(cid));
          el.classList.toggle("is-active", cid === id);
          el.classList.toggle("is-dim", !related.has(cid));
        });
        mapEl.classList.add("wires-focus");
        paintWires();
      }

      function clearActive() {
        activeId = null;
        document.querySelectorAll("[data-id]").forEach((el) => {
          el.classList.remove("is-related", "is-active", "is-dim");
        });
        mapEl.classList.remove("wires-focus");
        paintWires();
      }

      const wiresMode = () => mapEl.getAttribute("data-wires") || "hover";

      // El resaltado/atenuado por hover pertenece SOLO al modo "Al pasar".
      document.addEventListener("pointerover", (e) => {
        if (wiresMode() !== "hover") return;
        const el = e.target.closest("[data-id]");
        if (el) setActive(el.getAttribute("data-id"));
      });
      document.addEventListener("pointerout", (e) => {
        if (wiresMode() !== "hover") return;
        const el = e.target.closest("[data-id]");
        const rel =
          e.relatedTarget && e.relatedTarget.closest
            ? e.relatedTarget.closest("[data-id]")
            : null;
        if (el && el !== rel && !el.contains(e.relatedTarget)) clearActive();
      });
      document.addEventListener("focusin", (e) => {
        if (wiresMode() !== "hover") return;
        const el = e.target.closest && e.target.closest("[data-id]");
        if (el) setActive(el.getAttribute("data-id"));
      });
      document.addEventListener("focusout", (e) => {
        if (wiresMode() !== "hover") return;
        const el = e.target.closest && e.target.closest("[data-id]");
        if (el) clearActive();
      });

      /* Toggle de modo (Ocultar / Al pasar / Siempre) */
      const WIRES_KEY = "wayfinder:wires";
      function setWiresMode(mode) {
        if (!["off", "hover", "always"].includes(mode)) mode = "always";
        mapEl.setAttribute("data-wires", mode);
        try {
          localStorage.setItem(WIRES_KEY, mode);
        } catch {}
        document.querySelectorAll("[data-wires-mode]").forEach((b) => {
          const on = b.getAttribute("data-wires-mode") === mode;
          b.classList.toggle("is-on", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        if (mode !== "hover") clearActive();
        paintWires();
        scheduleWireLayout();
      }
      document.querySelectorAll("[data-wires-mode]").forEach((b) => {
        b.addEventListener("click", () =>
          setWiresMode(b.getAttribute("data-wires-mode"))
        );
      });

      window.addEventListener("resize", scheduleWireLayout);
      if (window.ResizeObserver)
        new ResizeObserver(scheduleWireLayout).observe(mapEl);
      if (document.fonts && document.fonts.ready)
        document.fonts.ready.then(scheduleWireLayout);

      let savedMode = "always";
      try {
        savedMode = localStorage.getItem(WIRES_KEY) || "always";
      } catch {}
      setWiresMode(savedMode);

      /* ---------- Tema claro / oscuro ---------- */
      const THEME_KEY = "wayfinder:theme";
      const themeBtn = document.querySelector("#theme-toggle");
      function applyTheme(theme) {
        const t = theme === "dark" ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", t);
        if (themeBtn) themeBtn.setAttribute("aria-checked", t === "dark" ? "true" : "false");
        try {
          localStorage.setItem(THEME_KEY, t);
        } catch {}
      }
      if (themeBtn) {
        // Sincroniza el estado del botón con el tema ya aplicado en <head>.
        const current =
          document.documentElement.getAttribute("data-theme") === "dark"
            ? "dark"
            : "light";
        themeBtn.setAttribute("aria-checked", current === "dark" ? "true" : "false");
        themeBtn.addEventListener("click", () => {
          const now = document.documentElement.getAttribute("data-theme");
          applyTheme(now === "dark" ? "light" : "dark");
        });
      }

      applyAll();
      scheduleWireLayout();
    </script>

